{
  "expo": {
    "name": "HormoSync: Personalized Nutrition and Lifestyle monitoring App for Women with PCOS",
    "slug": "hormosync-pcos-app",
    "scheme": "hormosync",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F2F1"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro"
    }
  }
}
